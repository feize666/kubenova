# Image tags
FRONTEND_IMAGE=ghcr.io/feize1995/aiops-frontend:latest
CONTROL_API_IMAGE=ghcr.io/feize1995/aiops-control-api:latest
RUNTIME_GATEWAY_IMAGE=ghcr.io/feize1995/aiops-runtime-gateway:latest

# Exposed host ports
FRONTEND_PORT=3000
CONTROL_API_PORT=4000
RUNTIME_GATEWAY_PORT=4100

# Database bootstrap
POSTGRES_USER=aiops
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aiops

# Control API runtime config
CONTROL_API_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
RUNTIME_GATEWAY_BASE_URL=ws://localhost:4100
RUNTIME_GATEWAY_PUBLIC_BASE_URL=
JWT_SECRET=replace-with-long-random-jwt-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
SWAGGER_ENABLED=false
DEFAULT_ADMIN_EMAIL=admin@local.dev
DEFAULT_ADMIN_PASSWORD=change-me-now
AI_MODEL_BASE_URL=https://api.openai.com/v1
AI_MODEL_API_KEY=
AI_MODEL_NAME=gpt-4o-mini
AI_MODEL_MAX_TOKENS=4096
AI_MODEL_TIMEOUT_MS=30000

# Runtime Gateway bootstrap/integration
RUNTIME_TOKEN_SECRET=replace-with-runtime-token-secret
RUNTIME_GATEWAY_INTERNAL_SECRET=replace-with-internal-shared-secret
CONTROL_API_INTERNAL_BASE_URL=http://control-api:4000

# Frontend
# 留空表示浏览器走同源 /api 代理
NEXT_PUBLIC_CONTROL_API_BASE=
