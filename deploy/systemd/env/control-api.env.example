# Control API environment template
PORT=4000
NODE_ENV=production

CONTROL_API_BASE_URL=http://127.0.0.1:4000
CORS_ORIGINS=http://127.0.0.1:3000

DATABASE_URL=postgres://aiops:change-me@127.0.0.1:5432/aiops
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=replace-with-long-random-jwt-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

RUNTIME_GATEWAY_BASE_URL=ws://127.0.0.1:4100
RUNTIME_GATEWAY_PUBLIC_BASE_URL=
RUNTIME_GATEWAY_INTERNAL_SECRET=replace-with-internal-shared-secret

SWAGGER_ENABLED=false
DEFAULT_ADMIN_EMAIL=admin@local.dev
DEFAULT_ADMIN_PASSWORD=change-me-now
AI_MODEL_BASE_URL=https://api.openai.com/v1
AI_MODEL_API_KEY=
AI_MODEL_NAME=gpt-4o-mini
AI_MODEL_MAX_TOKENS=2048
AI_MODEL_TIMEOUT_MS=30000
