{
  "name": "kubenova-frontend",
  "version": "1.1.1",
  "private": true,
  "scripts": {
    "dev": "node --max-old-space-size=1536 ./node_modules/next/dist/bin/next dev --turbo",
    "dev:webpack": "node --max-old-space-size=1536 ./node_modules/next/dist/bin/next dev --webpack",
    "dev:turbo": "node --max-old-space-size=1536 ./node_modules/next/dist/bin/next dev --turbo",
    "build": "next build",
    "build:stable": "node --max-old-space-size=2048 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "start:stable": "HOSTNAME=0.0.0.0 PORT=${PORT:-3000} node --max-old-space-size=1024 .next/standalone/server.js",
    "lint": "eslint",
    "check:cluster-routes": "node ./scripts/check-cluster-route-contracts.mjs",
    "check:delivery-iam-security": "node ./scripts/check-delivery-iam-security-contracts.mjs",
    "check:filters": "node ./scripts/check-filter-contracts.mjs",
    "check:drawers": "node ./scripts/check-drawer-contracts.mjs",
    "check:modals": "node ./scripts/check-modal-contracts.mjs",
    "check:network-storage-config": "node ./scripts/check-network-storage-config-contracts.mjs",
    "check:navigation": "node ./scripts/check-navigation.mjs",
    "check:observability-aiops": "node ./scripts/check-observability-aiops-workbench-contracts.mjs",
    "check:ops-actions-a11y": "node ./scripts/check-ops-actions-a11y.mjs",
    "check:responsive-a11y": "node ./scripts/check-responsive-a11y-contracts.mjs",
    "check:resource-page-surfaces": "node ./scripts/check-resource-page-surface-contracts.mjs",
    "check:resource-table": "node ./scripts/check-resource-table-contracts.mjs",
    "check:theme-tokens": "node ./scripts/check-theme-tokens.mjs",
    "check:ui-evidence": "node ./scripts/check-ui-evidence-contracts.mjs",
    "check:workload-routes": "node ./scripts/check-workload-route-contracts.mjs",
    "e2e:filters": "node ./scripts/filter-regression.mjs",
    "e2e:filters:matrix": "node ./scripts/filter-regression-matrix.mjs",
    "e2e:filters:list": "FILTER_MODE=list node ./scripts/filter-regression-matrix.mjs",
    "e2e:performance:switching": "node ./scripts/performance-switching.mjs",
    "e2e:performance:switching:smoke": "PERF_SAMPLE_COUNT=${PERF_SAMPLE_COUNT:-1} PERF_WARMUP_COUNT=${PERF_WARMUP_COUNT:-0} PERF_MAX_P95_MS=${PERF_MAX_P95_MS:-1500} PERF_MAX_ROUTE_MS=${PERF_MAX_ROUTE_MS:-2500} PERF_MAX_CONSOLE_ERRORS=${PERF_MAX_CONSOLE_ERRORS:-0} node ./scripts/performance-switching.mjs",
    "e2e:performance:switching:budget": "PERF_MAX_P95_MS=${PERF_MAX_P95_MS:-900} PERF_MAX_ROUTE_MS=${PERF_MAX_ROUTE_MS:-1800} PERF_MAX_ROUTE_REQUESTS=${PERF_MAX_ROUTE_REQUESTS:-80} PERF_MAX_ROUTE_API_REQUESTS=${PERF_MAX_ROUTE_API_REQUESTS:-30} PERF_MAX_SLOW_REQUEST_MS=${PERF_MAX_SLOW_REQUEST_MS:-1200} PERF_MAX_CONSOLE_ERRORS=${PERF_MAX_CONSOLE_ERRORS:-0} node ./scripts/performance-switching.mjs",
    "e2e:ui-tech:smoke": "node ./scripts/ui-tech-smoke.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@dagrejs/dagre": "^3.0.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^6.3.5",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "js-yaml": "^4.2.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "playwright": "^1.60.0",
    "typescript": "^5"
  }
}
